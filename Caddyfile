# Landing page
heritagemotor.app {
	tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key
	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com https://plausible.heritagemotor.app; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://images.unsplash.com; frame-src https://challenges.cloudflare.com; connect-src 'self' https://api.heritagemotor.app https://plausible.heritagemotor.app"
		-Server
	}

	# Contact form API → Go backend
	handle /api/v1/* {
		reverse_proxy api:8080
	}

	# Static landing files (clean URLs: /contact → /contact.html, etc.)
	handle {
		root * /srv/landing
		try_files {path} {path}.html
		file_server
	}

	handle_errors {
		rewrite * /404.html
		root * /srv/landing
		file_server
	}
}

# Go API
api.heritagemotor.app {
	tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key
	reverse_proxy api:8080
	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'none'; frame-ancestors 'none'"
		-Server
	}
}

# Plausible Analytics
stats.heritagemotor.app {
	tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key
	reverse_proxy plausible:8000
	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}
}

# PWA Next.js
app.heritagemotor.app {
	tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key
	reverse_proxy app:3000
	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		# PWA: allow camera for QR scanning
		Permissions-Policy "camera=(self), microphone=()"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob: https://*.your-objectstorage.com; connect-src 'self' https://api.heritagemotor.app"
		-Server
	}
}
