# ── Application ──────────────────────────────────────────────
APP_ENV=development                          # production
APP_PORT=3000
APP_BASE_URL=http://localhost:3000           # https://api.heritagemotor.app

# ── Database ─────────────────────────────────────────────────
POSTGRES_DB=heritage_motor
POSTGRES_USER=heritage_motor
POSTGRES_PASSWORD=password                   # openssl rand -hex 32
DATABASE_URL=postgresql://heritage_motor:password@localhost:5432/heritage_motor?sslmode=disable
APP_DB_PASSWORD=                             # openssl rand -hex 32 — password for heritage_app role (RLS)
DATABASE_APP_URL=                            # postgresql://heritage_app:<password>@localhost:5432/heritage_motor?sslmode=disable

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-256-bit-secret   # openssl rand -hex 32
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=                                # comma-separated origins (e.g. https://app.heritagemotor.app)

# ── S3 / Hetzner Object Storage ─────────────────────────────
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_BUCKET=heritage-motor-dev                 # heritage-motor-prod
S3_ACCESS_KEY=                               # from Hetzner console
S3_SECRET_KEY=                               # from Hetzner console
S3_REGION=eu-central

# ── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_xxxxx                      # from Resend dashboard
EMAIL_FROM=noreply@heritagemotor.app
CONTACT_EMAIL_TO=welcome@heritagemotor.app   # where contact form submissions are sent

# ── Cloudflare Turnstile (anti-bot on login + contact) ─────
TURNSTILE_SECRET_KEY=                        # from Cloudflare Dashboard > Turnstile (secret key)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=              # from Cloudflare Dashboard > Turnstile (site key)

# ── Superadmin (one-time bootstrap, see bootstrap.sh) ──────
SUPERADMIN_EMAIL=admin@heritagemotor.app
SUPERADMIN_PASSWORD=                         # strong password (upper+lower+digit+special, min 8)

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug                              # info

# ── Plausible Analytics (production only) ────────────────────
PLAUSIBLE_DB_PASSWORD=                       # openssl rand -hex 32
PLAUSIBLE_SECRET_KEY=                        # openssl rand -base64 48
PLAUSIBLE_TOTP_KEY=                          # openssl rand -base64 32
