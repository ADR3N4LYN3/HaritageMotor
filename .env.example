# Application
APP_ENV=development
APP_PORT=3000
APP_BASE_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://heritage_motor:password@localhost:5432/heritage_motor?sslmode=disable
POSTGRES_PASSWORD=password

# Auth
JWT_SECRET=change-this-to-a-256-bit-random-secret-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# S3 / Hetzner Object Storage
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_BUCKET=heritage-motor-dev
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-central

# Email (Resend)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=noreply@heritagemotor.app

# Logging
LOG_LEVEL=debug
